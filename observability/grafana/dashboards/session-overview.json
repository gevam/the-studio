{
  "id": null,
  "uid": "studio-sessions",
  "title": "Studio — Session Overview",
  "tags": ["studio"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Active Sessions",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "studio_active_sessions",
          "legendFormat": "Active"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "none"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Awaiting Human",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "studio_sessions_awaiting_human",
          "legendFormat": "Awaiting Human"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "thresholds": {
          "steps": [
            { "color": "green", "value": 0 },
            { "color": "yellow", "value": 1 }
          ]
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Open Friction Items",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "studio_open_friction_items",
          "legendFormat": "Open Friction"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "thresholds": {
          "steps": [
            { "color": "green", "value": 0 },
            { "color": "yellow", "value": 5 },
            { "color": "red", "value": 20 }
          ]
        }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Sessions Created",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "rate(studio_sessions_total[5m])",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "LLM Calls Rate",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "rate(studio_llm_calls_total[5m])",
          "legendFormat": "{{agent}} / {{model}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Design Friction Reported",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "rate(studio_design_friction_total[5m])",
          "legendFormat": "{{category}} / {{severity}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Verification Failures",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "rate(studio_verification_failures_total[5m])",
          "legendFormat": "{{check}}"
        }
      ]
    }
  ]
}
