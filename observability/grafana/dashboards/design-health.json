{
  "title": "Design Health",
  "uid": "design-health",
  "tags": ["studio", "design", "sprint-1"],
  "timezone": "browser",
  "refresh": "10s",
  "schemaVersion": 39,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Open Friction Items",
      "description": "Design friction items not yet resolved",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "thresholds": {
          "mode": "absolute",
          "steps": [
            { "value": null, "color": "green" },
            { "value": 3, "color": "yellow" },
            { "value": 7, "color": "red" }
          ]
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "studio_open_friction_items",
          "legendFormat": "Open friction"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Design Revisions (total)",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(studio_design_revisions_total)",
          "legendFormat": "Total revisions"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Verification Failures",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "thresholds": {
          "mode": "absolute",
          "steps": [
            { "value": null, "color": "green" },
            { "value": 1, "color": "yellow" },
            { "value": 5, "color": "red" }
          ]
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(studio_verification_failures_total)",
          "legendFormat": "Failures"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "LLM Cost (session total)",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "unit": "currencyUSD"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(studio_session_cost_usd_sum)",
          "legendFormat": "Total cost"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Friction by Category",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (category) (rate(studio_design_friction_total[5m]))",
          "legendFormat": "{{category}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Design Revision Rate",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (caused_by) (rate(studio_design_revisions_total[5m]))",
          "legendFormat": "caused_by={{caused_by}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Verification Failures by Check",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (check) (rate(studio_verification_failures_total[5m]))",
          "legendFormat": "{{check}}"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "LLM Calls by Agent",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (agent) (rate(studio_llm_calls_total[5m]))",
          "legendFormat": "{{agent}}"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Friction Score Distribution",
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum by (le, category) (rate(studio_design_friction_score_bucket[5m])))",
          "legendFormat": "p50 {{category}}"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.90, sum by (le, category) (rate(studio_design_friction_score_bucket[5m])))",
          "legendFormat": "p90 {{category}}"
        }
      ]
    }
  ],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {}
}
